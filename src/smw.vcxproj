    <Import Project="..\packages\sdl2.nuget.2.26.3\build\native\sdl2.nuget.targets" Condition="Exists('..\packages\sdl2.nuget.2.26.3\build\native\sdl2.nuget.targets')" />
  </ImportGroup>
  <Target Name="EnsureNuGetPackageBuildImports" BeforeTargets="PrepareForBuild">
    <PropertyGroup>
      <ErrorText>This project references NuGet package(s) that are missing on this computer. Use NuGet Package Restore to download them.  For more information, see http://go.microsoft.com/fwlink/?LinkID=322105. The missing file is {0}.</ErrorText>
    </PropertyGroup>
    <Error Condition="!Exists('..\packages\sdl2.nuget.redist.2.26.3\build\native\sdl2.nuget.redist.targets')" Text="$([System.String]::Format('$(ErrorText)', '..\packages\sdl2.nuget.redist.2.26.3\build\native\sdl2.nuget.redist.targets'))" />
    <Error Condition="!Exists('..\packages\sdl2.nuget.2.26.3\build\native\sdl2.nuget.targets')" Text="$([System.String]::Format('$(ErrorText)', '..\packages\sdl2.nuget.2.26.3\build\native\sdl2.nuget.targets'))" />
  </Target>
  <!-- Shared recomp-ui assets -> $(OutDir)assets\ (SDL_GetBasePath). -->
  <Target Name="CopyLauncherAssets" AfterTargets="Build" Condition="'$(Platform)'=='x64'">
    <ItemGroup>
      <LauncherFonts Include="$(SolutionDir)recomp-ui\assets\common\fonts\*" />
      <LauncherImgs Include="$(SolutionDir)recomp-ui\assets\common\img\*;$(SolutionDir)recomp-ui\assets\consoles\snes\img\*" />
    </ItemGroup>
    <Copy SourceFiles="@(LauncherFonts)" DestinationFolder="$(OutDir)assets\fonts" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(LauncherImgs)"  DestinationFolder="$(OutDir)assets\img"   SkipUnchangedFiles="true" />
  </Target>

  <!-- Per-game launcher art (boxart.tga) -> assets\img\. -->
  <Target Name="CopyGameLauncherAssets" AfterTargets="Build" Condition="'$(Platform)'=='x64'">
    <ItemGroup>
      <GameLauncherAssets Include="$(SolutionDir)recomp\launcher\*" />
    </ItemGroup>
    <Copy SourceFiles="@(GameLauncherAssets)" DestinationFolder="$(OutDir)assets\img" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CopyCoopPatch" AfterTargets="Build">
    <Copy SourceFiles="$(SolutionDir)recomp\coop\smw_coop.ips"
          DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>
</Project>
